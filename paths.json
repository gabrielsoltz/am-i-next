{
  "schemaVersion": 1,
  "name": "am-i-next critical developer-credential locations",
  "description": "Filesystem locations that recent supply-chain attacks (Shai-Hulud, nx s1ngularity) and AI-history harvesters (ghosttype) target on developer machines. Language-neutral so any secret scanner can consume it. Paths are ~-relative; expand ~ to the user's home directory. Non-existent paths should be skipped.",
  "updated": "2026-05-23",
  "repository": "https://github.com/gabrielsoltz/am-i-next",
  "rawUrl": "https://raw.githubusercontent.com/gabrielsoltz/am-i-next/main/paths.json",
  "sources": [
    "https://securitylabs.datadoghq.com/articles/shai-hulud-2.0-npm-worm/",
    "https://www.microsoft.com/en-us/security/blog/2025/12/09/shai-hulud-2-0-guidance-for-detecting-investigating-and-defending-against-the-supply-chain-attack/",
    "https://blog.gitguardian.com/the-nx-s1ngularity-attack-inside-the-credential-leak/",
    "https://www.stepsecurity.io/blog/supply-chain-security-alert-popular-nx-build-system-package-compromised-with-data-stealing-malware",
    "https://semgrep.dev/blog/2025/security-alert-nx-compromised-to-steal-wallets-and-credentials/",
    "https://github.com/xFreed0m/ghosttype"
  ],
  "scanLocations": {
    "common": [
      { "path": "~/.aws", "category": "cloud" },
      { "path": "~/.azure", "category": "cloud" },
      { "path": "~/.config/gcloud", "category": "cloud" },
      { "path": "~/.oci", "category": "cloud" },
      { "path": "~/.kube", "category": "container" },
      { "path": "~/.docker", "category": "container" },
      { "path": "~/.minikube", "category": "container" },
      { "path": "~/.ssh", "category": "ssh" },
      { "path": "~/.gitconfig", "category": "git" },
      { "path": "~/.git-credentials", "category": "git" },
      { "path": "~/.config/gh", "category": "git" },
      { "path": "~/.npmrc", "category": "registry" },
      { "path": "~/.pypirc", "category": "registry" },
      { "path": "~/.gem/credentials", "category": "registry" },
      { "path": "~/.cargo/credentials.toml", "category": "registry" },
      { "path": "~/.gradle/gradle.properties", "category": "registry" },
      { "path": "~/.m2/settings.xml", "category": "registry" },
      { "path": "~/.nuget", "category": "registry" },
      { "path": "~/.terraformrc", "category": "iac" },
      { "path": "~/.terraform.d/credentials.tfrc.json", "category": "iac" },
      { "path": "~/.config/op", "category": "secrets-manager" },
      { "path": "~/.netrc", "category": "vpn-network" },
      { "path": "~/.config/wireguard", "category": "vpn-network" },
      { "path": "~/.vault-token", "category": "secrets-manager" },
      { "path": "~/.claude", "category": "ai", "note": "Claude Code: .credentials.json + projects/**/*.jsonl, history.jsonl, tasks/" },
      { "path": "~/.codex", "category": "ai", "note": "OpenAI Codex CLI: state_5.sqlite, logs_2.sqlite" },
      { "path": "~/.gemini", "category": "ai" },
      { "path": "~/.codeium", "category": "ai", "note": "Codeium / Windsurf" },
      { "path": "~/.cursor", "category": "ai" },
      { "path": "~/.continue", "category": "ai", "note": "Continue.dev: config + session history" },
      { "path": "~/.config", "category": "config-broad" },
      { "path": "~/.ethereum", "category": "crypto-wallet", "note": "Geth keystore (UTC--* key files)" },
      { "path": "~/.electrum", "category": "crypto-wallet" },
      { "path": "~/.bitcoin", "category": "crypto-wallet" },
      { "path": "~/.monero", "category": "crypto-wallet" },
      { "path": "~/.config/solana", "category": "crypto-wallet", "note": "Solana CLI keypairs (id.json)" },
      { "path": "~/.config/Exodus", "category": "crypto-wallet" },
      { "path": "~/.config/Electrum", "category": "crypto-wallet" },
      { "path": "~/.config/atomic", "category": "crypto-wallet" },
      { "path": "~/.gnupg", "category": "gpg" },
      { "path": "~/.bash_history", "category": "shell-history" },
      { "path": "~/.zsh_history", "category": "shell-history" },
      { "path": "~/.fish/fish_history", "category": "shell-history" },
      { "path": "~/code", "category": "project" },
      { "path": "~/projects", "category": "project" },
      { "path": "~/dev", "category": "project" },
      { "path": "~/workspace", "category": "project" },
      { "path": "~/src", "category": "project" },
      { "path": "/tmp", "category": "temp" }
    ],
    "macos": [
      { "path": "~/Library/Application Support/Code/User", "category": "ide" },
      { "path": "~/Library/Application Support/Cursor/User", "category": "ide", "note": "also Cursor AI history (state.vscdb)" },
      { "path": "~/Library/Application Support/JetBrains", "category": "ide" },
      { "path": "~/Library/Application Support/GitHub Desktop", "category": "ide" },
      { "path": "~/Library/Caches/Homebrew", "category": "cache" },
      { "path": "~/Library/Application Support/AWS", "category": "cloud" },
      { "path": "~/Library/Preferences", "category": "app-prefs" },
      { "path": "~/Library/Keychains", "category": "keychain" },
      { "path": "~/Library/Containers", "category": "container" },
      { "path": "~/Library/Application Support/Slack", "category": "app" },
      { "path": "~/Library/Application Support/Claude", "category": "ai" },
      { "path": "~/Library/Application Support/com.openai.chat", "category": "ai", "note": "ChatGPT Desktop (conversations-v3-*/*.data)" },
      { "path": "~/Library/Application Support/Windsurf/User", "category": "ai" },
      { "path": "~/Library/Application Support/Google/Chrome", "category": "browser" },
      { "path": "~/Library/Application Support/BraveSoftware/Brave-Browser", "category": "browser" },
      { "path": "~/Library/Application Support/Microsoft Edge", "category": "browser" },
      { "path": "~/Library/Application Support/Firefox", "category": "browser" },
      { "path": "~/Library/Application Support/Arc", "category": "browser" },
      { "path": "~/Library/Application Support/Exodus", "category": "crypto-wallet" },
      { "path": "~/Library/Application Support/Electrum", "category": "crypto-wallet" },
      { "path": "~/Library/Application Support/Ledger Live", "category": "crypto-wallet" },
      { "path": "~/Library/Application Support/atomic", "category": "crypto-wallet" }
    ],
    "linux": [
      { "path": "~/.config/Code/User", "category": "ide" },
      { "path": "~/.config/Cursor/User", "category": "ide", "note": "also Cursor AI history" },
      { "path": "~/.config/Windsurf/User", "category": "ai" },
      { "path": "~/.config/JetBrains", "category": "ide" },
      { "path": "~/.local/share", "category": "data-broad" },
      { "path": "~/.config/google-chrome", "category": "browser" },
      { "path": "~/.config/chromium", "category": "browser" },
      { "path": "~/.config/BraveSoftware", "category": "browser" },
      { "path": "~/.config/microsoft-edge", "category": "browser" },
      { "path": "~/.mozilla/firefox", "category": "browser" },
      { "path": "~/snap", "category": "app" },
      { "path": "~/.var/app", "category": "app" },
      { "path": "/etc/environment", "category": "system" },
      { "path": "/etc/profile.d", "category": "system" }
    ]
  },
  "excludePatterns": [
    "\\.git/objects",
    "\\.git/pack",
    "node_modules",
    "__pycache__",
    "/Cache/",
    "/Code Cache/",
    "/GPUCache/",
    "/ShaderCache/",
    "/Service Worker/CacheStorage/",
    "/CacheStorage/",
    "cache2/entries",
    "\\.pyc$",
    "\\.class$",
    "\\.so$",
    "\\.dylib$",
    "\\.dmg$",
    "\\.pkg$",
    "\\.iso$",
    "\\.tar$",
    "\\.gz$",
    "\\.zip$",
    "\\.jpg$",
    "\\.jpeg$",
    "\\.png$",
    "\\.gif$",
    "\\.mp4$",
    "\\.mov$",
    "\\.pdf$"
  ]
}
